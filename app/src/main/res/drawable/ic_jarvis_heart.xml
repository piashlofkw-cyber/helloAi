<?xml version="1.0" encoding="utf-8"?>
<!-- Animated heart icon for girlfriend mode -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    
    <!-- Outer glow circle -->
    <path
        android:fillColor="#4D00BCD4"
        android:pathData="M100,100m-80,0a80,80 0,1 1,160 0a80,80 0,1 1,-160 0z"/>
    
    <!-- Main AI core circle -->
    <path
        android:fillColor="@color/primary"
        android:pathData="M100,100m-60,0a60,60 0,1 1,120 0a60,60 0,1 1,-120 0z"/>
    
    <!-- Heart shape in center -->
    <path
        android:fillColor="@color/accent"
        android:pathData="M100,85c-5.5,-11 -20,-15 -30,-5 -10,10 -5,25 5,35 5,5 20,20 25,25 5,-5 20,-20 25,-25 10,-10 15,-25 5,-35 -10,-10 -24.5,-6 -30,5z"/>
    
    <!-- Neural connections -->
    <path
        android:pathData="M70,70L85,85M115,85L130,70M70,130L85,115M115,115L130,130"
        android:strokeColor="@color/primary"
        android:strokeWidth="2"/>
    
    <!-- Energy particles (using path instead of circle) -->
    <path android:fillColor="@color/accent" 
        android:pathData="M60,60m-3,0a3,3 0,1 1,6 0a3,3 0,1 1,-6 0z"/>
    <path android:fillColor="@color/accent" 
        android:pathData="M140,60m-3,0a3,3 0,1 1,6 0a3,3 0,1 1,-6 0z"/>
    <path android:fillColor="@color/accent" 
        android:pathData="M60,140m-3,0a3,3 0,1 1,6 0a3,3 0,1 1,-6 0z"/>
    <path android:fillColor="@color/accent" 
        android:pathData="M140,140m-3,0a3,3 0,1 1,6 0a3,3 0,1 1,-6 0z"/>
    
</vector>
